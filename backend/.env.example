# Server configuration
PORT=5000

# MongoDB connection string
# Local MongoDB:      mongodb://127.0.0.1:27017/smarttask
# MongoDB Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smarttask
MONGODB_URI=mongodb://127.0.0.1:27017/smarttask

# JWT authentication
# Use a long, random secret in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=development
