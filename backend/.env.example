# Server configuration
PORT=5000

# MongoDB connection string
# Local MongoDB:      mongodb://127.0.0.1:27017/smarttask
# MongoDB Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smarttask
MONGODB_URI=mongodb://127.0.0.1:27017/smarttask

# JWT authentication
# Use a long, random secret in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Environment
# Use "production" when deploying so error stack traces are hidden.
NODE_ENV=development

# --- Deployment notes ---
# In production (Render, Railway, Fly.io, etc.) set these as host env vars:
#   NODE_ENV=production
#   MONGODB_URI=<your Atlas connection string>
#   JWT_SECRET=<a long random secret>
# and add the host's outbound IP (or 0.0.0.0/0) to the Atlas Network Access list.
